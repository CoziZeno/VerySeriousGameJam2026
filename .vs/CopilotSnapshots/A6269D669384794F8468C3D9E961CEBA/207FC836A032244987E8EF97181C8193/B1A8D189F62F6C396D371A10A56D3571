// Common utility functions for the HandPaintedStylizedURP shader.
// Expected include order:
// 1) Core.hlsl / Lighting.hlsl
// 2) texture/sampler declarations
// 3) this file

#ifndef HANDPAINTED_COMMON_INCLUDED
#define HANDPAINTED_COMMON_INCLUDED

float hash11(float p)
{
    p = frac(p * 0.1031);
    p *= p + 33.33;
    p *= p + p;
    return frac(p);
}

float hash21(float2 p)
{
    p = frac(p * float2(123.34, 456.21));
    p += dot(p, p + 34.345);
    return frac(p.x * p.y);
}

float2 rotate2d(float2 p, float a)
{
    float s = sin(a);
    float c = cos(a);
    return float2(c * p.x - s * p.y, s * p.x + c * p.y);
}

float valueNoise(float2 p)
{
    float2 i = floor(p);
    float2 f = frac(p);
    f = f * f * (3.0 - 2.0 * f);

    float a = hash21(i);
    float b = hash21(i + float2(1, 0));
    float c = hash21(i + float2(0, 1));
    float d = hash21(i + float2(1, 1));

    return lerp(lerp(a, b, f.x), lerp(c, d, f.x), f.y);
}

float fbm(float2 p)
{
    float v = 0.0;
    float amp = 0.5;
    [unroll]
    for (int i = 0; i < 4; i++)
    {
        v += amp * valueNoise(p);
        p = p * 2.07 + 19.19;
        amp *= 0.5;
    }
    return v;
}

float3 TriplanarWeights(float3 n)
{
    n = abs(n);
    return n / max(n.x + n.y + n.z, 1e-5);
}

half SampleBrushTriplanar(float3 positionWS, float3 normalWS, half tiling)
{
    float3 w = TriplanarWeights(normalWS);

    float2 uvX = positionWS.yz * tiling;
    float2 uvY = positionWS.xz * tiling;
    float2 uvZ = positionWS.xy * tiling;

    half bx = SAMPLE_TEXTURE2D(_BrushTex, sampler_BrushTex, uvX).r;
    half by = SAMPLE_TEXTURE2D(_BrushTex, sampler_BrushTex, uvY).r;
    half bz = SAMPLE_TEXTURE2D(_BrushTex, sampler_BrushTex, uvZ).r;

    return bx * w.x + by * w.y + bz * w.z;
}

half TriplanarNoise(float3 positionWS, float3 normalWS, half noiseScale)
{
    float3 w = TriplanarWeights(normalWS);

    float2 xz = positionWS.yz * noiseScale;
    float2 yz = positionWS.xz * noiseScale;
    float2 xy = positionWS.xy * noiseScale;

    half n1 = fbm(xz);
    half n2 = fbm(yz);
    half n3 = fbm(xy);

    return n1 * w.x + n2 * w.y + n3 * w.z;
}

half CrackPattern(float3 positionWS, half crackScale, half crackWidth)
{
    float2 p = positionWS.xz * crackScale;
    float2 i = floor(p);
    float2 f = frac(p);

    float d1 = 1e9;
    float d2 = 1e9;

    [unroll]
    for (int y = -1; y <= 1; y++)
    {
        [unroll]
        for (int x = -1; x <= 1; x++)
        {
            float2 g = float2(x, y);
            float2 o = float2(hash21(i + g), hash21(i + g + float2(11.7, 5.3)));
            float2 r = g + o - f;
            float d = dot(r, r);

            if (d < d1)
            {
                d2 = d1;
                d1 = d;
            }
            else if (d < d2)
            {
                d2 = d;
            }
        }
    }

    float edge = (d2 - d1) * 6.0;
    return 1.0 - smoothstep(crackWidth, crackWidth + 0.12, edge);
}

half CavityMask(float3 positionWS, float3 normalWS, half cavityScale, half cavityWidth)
{
    half surface = TriplanarNoise(positionWS * 0.25, normalWS, cavityScale * 0.25);
    half cavities = fbm(positionWS.xz * cavityScale + normalWS.xy * 3.0);
    half depth = saturate((1.0 - normalWS.y) * 0.35 + cavities * 0.65);
    depth *= lerp(0.7, 1.3, surface);
    return smoothstep(cavityWidth, 1.0, depth);
}

half3 AmbientGradient(float3 normalWS, half3 skyColor, half3 groundColor)
{
    half t = saturate(normalWS.y * 0.5h + 0.5h);
    return lerp(groundColor, skyColor, t);
}

#endif
